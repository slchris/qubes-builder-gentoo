#!/bin/bash
# vim: set ts=4 sw=4 sts=4 et :

### prepare-chroot-base : create a base chroot instance of Gentoo

set -e
if [ "$VERBOSE" -ge 2 ] || [ "$DEBUG" -gt 0 ]; then
    set -x
fi

INSTALLDIR="$1"
DISTRO="$2"
FLAVOR="${3:-gnome}"

[ -z "${CACHE_DIR}" ] && CACHE_DIR="/tmp"
mkdir -p "${CACHE_DIR}"

# GPG_KEYRING="$(readlink -f ${CACHE_DIR}/gentoo-trustedkeys.gpg)"
# GPG_OPTS="--no-default-keyring --keyring $GPG_KEYRING"
GPG_OPTS=""

# shellcheck source=scripts/distribution.sh
. ${TEMPLATE_CONTENT_DIR}/distribution.sh

if ! [ -f "${INSTALLDIR}/etc/.prepared_base" ]; then
    STAGE_FLAVOR="latest-stage3-amd64-systemd"
    GENTOO_DISTFILES="${GENTOO_DISTFILES:-https://mirrors.tuna.tsinghua.edu.cn/gentoo}"

    STAGE_DIR="${CACHE_DIR}/stage"
    PORTAGE_DIR="${CACHE_DIR}/portage"

    echo "  --> Importing Gentoo keys..."
    gpg $GPG_OPTS --import "${TEMPLATE_CONTENT_DIR}/../keys/gentoo-release.asc.20250806"

    ## STAGE3
    if ! [ -f "${INSTALLDIR}/etc/.extracted_stage3" ]; then
        # Get info about latest Gentoo stage3
        STAGE_INFO="${GENTOO_DISTFILES}/releases/amd64/autobuilds/${STAGE_FLAVOR}.txt"
        wget -q -N -P "${STAGE_DIR}" "${STAGE_INFO}"

        # Extract stage3 URL and name
        STAGE_BASEURL="${GENTOO_DISTFILES}/releases/amd64/autobuilds"
        STAGE_URL="${STAGE_BASEURL}/$(sed -n '6p' ${STAGE_DIR}/${STAGE_FLAVOR}.txt | awk '{print $1}')"
        STAGE_FILE="$(basename "${STAGE_URL}")"

        # Download the stage3
        echo "  --> Downloading Gentoo $DISTRO stage3..."
        wget -q -N -P "${STAGE_DIR}" "${STAGE_URL}"{,.DIGESTS}

        echo "  --> Verifying Gentoo $DISTRO stage3..."
        pushd "$STAGE_DIR" || exit 1
        if ! gpg $GPG_OPTS --verify "$STAGE_FILE.DIGESTS"; then
            echo "    --> Wrong signature for $STAGE_FILE"
            exit 1
        fi
        if ! awk '/SHA512 HASH/{getline;print}' "$STAGE_FILE.DIGESTS" | sed '/CONTENTS/d' | sha512sum -c; then
            echo "    --> Wrong checksum for $STAGE_FILE"
            exit 1
        fi
        popd

        # Extract the stage3
        echo "  --> Extracting Gentoo $DISTRO stage3..."
        tar Jxfp "${STAGE_DIR}/${STAGE_FILE}" -C "${INSTALLDIR}" --xattrs-include='*.*' --numeric-owner

        touch "${INSTALLDIR}/etc/.extracted_stage3"
    fi

    ## PORTAGE
    if ! [ -f "${INSTALLDIR}/etc/.extracted_portage" ]; then
        # Download latest Portage
        echo "  --> Downloading latest Portage..."
        # we download the latest archive with a date
        # Extract just the filename; the old 'portage.*.tar.bz2">' greedily
        # grabbed extra HTML (e.g. TUNA's title="..." attribute) and corrupted the
        # URL. Match the bare filename and take the newest.
        PORTAGE_LATEST="$(curl -s -L ${GENTOO_DISTFILES}/snapshots/ | grep -oE 'portage-[0-9]+\.tar\.bz2' | sort -u | tail -1)"
        if [ -z "$PORTAGE_LATEST" ]; then
            echo "    --> Cannot determinate latest Portage date"
            exit 1
        fi
        PORTAGE_URL="${GENTOO_DISTFILES}/snapshots/${PORTAGE_LATEST}"
        wget -q -P "${PORTAGE_DIR}" "${PORTAGE_URL}"{,.gpgsig,.md5sum}

        echo "  --> Verifying latest Portage..."
        pushd "$PORTAGE_DIR" || exit 1
        if ! gpg $GPG_OPTS --verify "${PORTAGE_LATEST}.gpgsig" "${PORTAGE_LATEST}"; then
            echo "    --> Wrong signature for ${PORTAGE_LATEST}"
            exit 1
        fi
        if ! md5sum -c "${PORTAGE_LATEST}.md5sum"; then
            echo "    --> Wrong checksum for ${PORTAGE_LATEST}"
            exit 1
        fi
        popd

        # Extract Portage
        echo "  --> Extracting latest Portage..."
        tar xfp "${PORTAGE_DIR}/${PORTAGE_LATEST}" -C "${INSTALLDIR}/usr"

        # Configure Portage
        echo "  --> Configuring Portage..."
        mkdir -p "${INSTALLDIR}/usr/portage/distfiles"
        mkdir -p "${INSTALLDIR}/usr/portage/packages"
        # Python target: pin to python3_13, Gentoo's DEFAULT stable interpreter.
        # python3_14 is stable-but-not-default and still in transition (its build
        # toolchain isn't fully settled), which makes packages like pillow fail
        # their PEP517 wheel build. Using 3.13 (the official default) is "following
        # upstream", not downgrading — 3.14 stays available in PYTHON_TARGETS.
        PYTHON_SINGLE_TARGET="${PYTHON_SINGLE_TARGET:-python3_13}"
        PYTHON_TARGETS="${PYTHON_TARGETS:-python3_13 python3_14}"
        GENTOO_MIRRORS_CHROOT="${GENTOO_MIRRORS:-https://mirrors.tuna.tsinghua.edu.cn/gentoo}"
        # Binary host: pull prebuilt packages from the China mirror instead of
        # compiling everything. This dodges packages whose from-source build is
        # currently broken on the latest tree (e.g. pillow's PEP517 wheel build)
        # AND massively speeds up the whole template build. The binpkgs are
        # GPG-signed by the Gentoo release key (imported above).
        BINHOST_URI_CHROOT="${BINHOST_URI:-https://mirrors.tuna.tsinghua.edu.cn/gentoo/releases/amd64/binpackages/23.0/x86-64}"
        cat >> "${INSTALLDIR}/etc/portage/make.conf" << EOF
ACCEPT_KEYWORDS="amd64"
ACCEPT_LICENSE="*"
VIDEO_CARDS=""
PYTHON_SINGLE_TARGET="${PYTHON_SINGLE_TARGET}"
PYTHON_TARGETS="${PYTHON_TARGETS}"
GENTOO_MIRRORS="${GENTOO_MIRRORS_CHROOT}"
FEATURES="\${FEATURES} getbinpkg -binpkg-request-signature"
PORTAGE_BINHOST="${BINHOST_URI_CHROOT}"
EMERGE_DEFAULT_OPTS="\${EMERGE_DEFAULT_OPTS} --binpkg-respect-use=y --getbinpkgonly=n"
EOF
        # Don't require binpkg GPG signatures: the Gentoo binhost's binary-package
        # signing key isn't set up in this fresh chroot, and the mirror (TUNA) is
        # trusted. Configure the binrepo to skip signature verification.
        mkdir -p "${INSTALLDIR}/etc/portage/binrepos.conf"
        cat > "${INSTALLDIR}/etc/portage/binrepos.conf/gentoobinhost.conf" << EOF
[binhost]
priority = 1
sync-uri = ${BINHOST_URI_CHROOT}
EOF
        touch "${INSTALLDIR}/etc/.extracted_portage"
    fi

    prepareChroot "${INSTALLDIR}"
    mountCache "${CACHE_DIR}" "${INSTALLDIR}"

    # The build node has NO proxy and can't reach github.com, but the qubes
    # component ebuilds fetch their source via git-r3 from github. Ship the
    # component source repos as local git mirrors (packaged on the dev box, in
    # this component's mirror/ dir) and redirect github.com/QubesOS/ to them via
    # git's insteadOf, so git-r3 clones locally with no network.
    QUBES_SRC_MIRROR_TARBALL="${QUBES_SRC_MIRROR_TARBALL:-${TEMPLATE_CONTENT_DIR}/../mirror/qubes-src-mirror.tar.gz}"
    if [ -f "${QUBES_SRC_MIRROR_TARBALL}" ]; then
        echo "  --> Installing local qubes source mirror + git insteadOf redirect"
        mkdir -p "${INSTALLDIR}/var/cache/qubes-src-mirror"
        # tarball contains a top-level qubes-src-mirror/ dir with *.git bare mirrors;
        # strip it so the repos land directly under /var/cache/qubes-src-mirror.
        tar -xzf "${QUBES_SRC_MIRROR_TARBALL}" -C "${INSTALLDIR}/var/cache/qubes-src-mirror" --strip-components=1
        # git-r3 does 'git ls-remote https://github.com/QubesOS/<repo>.git' etc.;
        # rewrite that prefix to the local mirror path (bare repos named <repo>.git).
        # Write /etc/gitconfig DIRECTLY instead of `git config --system`: at this
        # point stage3 is only just extracted and git isn't installed yet (it's
        # emerged later as a dep), so the git binary doesn't exist. A plain file
        # is read by git as soon as it's present, and needs no binary to write.
        cat >> "${INSTALLDIR}/etc/gitconfig" <<'EOF'
[url "/var/cache/qubes-src-mirror/"]
	insteadOf = https://github.com/QubesOS/
EOF
    fi

    # Pre-seed distfiles the no-proxy node can't fetch. app-text/pandoc-bin pulls
    # a prebuilt tarball from github.com/jgm via SRC_URI (NOT git-r3, so the git
    # insteadOf above doesn't cover it). Drop any tarballs shipped in mirror/distfiles
    # into the chroot's distfiles cache so portage finds them locally and never hits
    # github. mountCache has already bind-mounted /var/cache/distfiles, so copy there.
    QUBES_DISTFILES_DIR="${QUBES_DISTFILES_DIR:-${TEMPLATE_CONTENT_DIR}/../mirror/distfiles}"
    if [ -d "${QUBES_DISTFILES_DIR}" ]; then
        echo "  --> Pre-seeding local distfiles (pandoc-bin etc.)"
        mkdir -p "${INSTALLDIR}/var/cache/distfiles"
        cp -a "${QUBES_DISTFILES_DIR}"/* "${INSTALLDIR}/var/cache/distfiles/" 2>/dev/null || true
        chrootCmd "${INSTALLDIR}" "chown -R portage:portage /var/cache/distfiles 2>/dev/null || true"
    fi

    # Prepare and sync the Gentoo ebuild tree.
    mkdir -p "${INSTALLDIR}/var/db/repos/gentoo"
    mkdir -p "${INSTALLDIR}/etc/portage/repos.conf"
    # Point the tree's rsync at a China mirror (overridable). The stage3 default
    # is rsync.gentoo.org (slow from CN); TUNA mirrors gentoo-portage over rsync.
    GENTOO_SYNC_URI="${GENTOO_SYNC_URI:-rsync://mirrors.tuna.tsinghua.edu.cn/gentoo-portage}"
    cat > "${INSTALLDIR}/etc/portage/repos.conf/gentoo.conf" <<EOF
[DEFAULT]
main-repo = gentoo

[gentoo]
location = /var/db/repos/gentoo
sync-type = rsync
sync-uri = ${GENTOO_SYNC_URI}
auto-sync = yes
EOF
    # Prefer emerge-webrsync (unpacks the already-fetched HTTP snapshot from the
    # mirror — no rsync daemon, no pty) and fall back to rsync only if needed.
    # The old 'emerge --sync' hit "openpty failed: out of pty devices" in the
    # container and pulled the whole tree over the wall.
    chrootCmd "${INSTALLDIR}" "emerge-webrsync -q || emerge --sync -q"

    # Set the Portage profile RIGHT AFTER the tree sync, BEFORE any emerge in this
    # script (eselect-python, freetype/harfbuzz, the base @world below). The profile
    # governs the merged-usr/split-usr layout and USE defaults, so if we compile
    # anything under the stage3's built-in default profile first, those packages get
    # the wrong layout — that's how the earlier build ended up split-usr on the
    # (now-removed) 17.1 profile even though 02_install_groups.sh later ran
    # setPortageProfile. Pin it here to GENTOO_PROFILE (default 23.0/desktop/systemd,
    # a merged-usr profile matching the current merged-usr stage3). The tree must be
    # synced first (the profile dir lives in the tree). eselect-repository/profiles
    # exist after the sync.
    GENTOO_PROFILE="${GENTOO_PROFILE:-default/linux/amd64/23.0/desktop/systemd}"
    echo "  --> Selecting Portage profile early: ${GENTOO_PROFILE}"
    chrootCmd "${INSTALLDIR}" "eselect profile set ${GENTOO_PROFILE}"

    # Make portage ITSELF run on python3.13, not a stage3 python3.14 default.
    # portage-on-3.14 has an asyncio bug (Gentoo bug 967199) — the BinpkgFetcher
    # crashes getbinpkg with "RuntimeError: Event loop is closed". Do this AFTER
    # the tree sync, not right after stage3 extraction: a minimal stage3 has no
    # app-eselect/eselect-python module yet ("Can't load module python"), so the
    # eselect call silently no-ops and portage stays on 3.14. With the tree in
    # place we can install the module, then select 3.13 (a no-op if it's already
    # the default). All guarded so a stage3 that lacks 3.13 doesn't hard-fail.
    chrootCmd "${INSTALLDIR}" "emerge --oneshot --noreplace app-eselect/eselect-python 2>/dev/null || true"
    chrootCmd "${INSTALLDIR}" "eselect python set python3.13 || eselect python set --python3 python3.13 || true"
    chrootCmd "${INSTALLDIR}" "eselect python list 2>/dev/null | grep -i '\\*' || true"

    # Setup binary package mirror if requested
    # This is a fragile method as there no built-in Gentoo method
    # for verifying binary packages hosts. It serves only to check
    # mirror owner before adding it into the system. Once added,
    # nothing will prevent emerging a package if the content
    # has changed since the first check.
    # GENTOO_MIRROR=https://gentoo.notset.fr/repo/standard/gnome+9FA64B92F95E706BF28E2CA6484010B5CDC576E2
    if [ -n "${GENTOO_MIRROR}" ]; then
        GENTOO_MIRROR_KEY="$(echo "${GENTOO_MIRROR}"+ | cut -d '+' -f2)"
        GENTOO_MIRROR="$(echo "${GENTOO_MIRROR}"+ | cut -d '+' -f1)"
        if [ -n "${GENTOO_MIRROR_KEY}" ]; then
            if [ -e "${TEMPLATE_CONTENT_DIR}/../keys/${GENTOO_MIRROR_KEY}.asc" ]; then
                gpg $GPG_OPTS --import "${TEMPLATE_CONTENT_DIR}/../keys/${GENTOO_MIRROR_KEY}.asc"
                wget -q -P "${CACHE_DIR}" "${GENTOO_MIRROR}/${FLAVOR}"/Packages{,.gpgsig}
                pushd "${CACHE_DIR}" || exit 1
                if ! gpg $GPG_OPTS --verify Packages.gpgsig Packages; then
                    echo "    --> Wrong signature for ${GENTOO_MIRROR}/${FLAVOR}/Packages"
                    exit 1
                fi
                popd
            else
                echo "Cannot find key ${GENTOO_MIRROR_KEY}.asc in builder-gentoo."
                exit 1
            fi
        fi
        cat >> "${INSTALLDIR}/etc/portage/make.conf" << EOF
FEATURES="\$FEATURES getbinpkg"
PORTAGE_BINHOST="${GENTOO_MIRROR}/${FLAVOR}"
EOF
    fi

    # See https://forums.gentoo.org/viewtopic-p-8636878.html?sid=abbdb9e370551ba0e1c919fe08a6d5e0#8636878
    # freetype<->harfbuzz circular-dep bootstrap (upstream). With PYTHON_SINGLE_TARGET
    # pinned to python3_13 above, the glib->docutils->pillow chain builds cleanly, so
    # no USE-flag surgery is needed here anymore — this is the upstream form.
    chrootCmd "${INSTALLDIR}" 'USE="-truetype" emerge --oneshot freetype harfbuzz'
    chrootCmd "${INSTALLDIR}" 'USE="truetype harfbuzz" emerge --oneshot freetype harfbuzz'
    echo "media-libs/freetype harfbuzz" > "${INSTALLDIR}/etc/portage/package.use/freetype"

    # Install needed dependencies
    pkgs="fakeroot sudo lsb-release"
    chrootCmd "${INSTALLDIR}" "emerge ${EMERGE_OPTS} -n $pkgs"

    # Use app-alternatives
    chrootCmd "${INSTALLDIR}" "emerge ${EMERGE_OPTS} app-alternatives/{awk,bc,bzip2,cpio,gzip,lex,sh,tar,yacc}"

    touch "${INSTALLDIR}/etc/.prepared_base"
fi
